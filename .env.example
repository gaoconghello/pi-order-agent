# OpenAI 兼容模式下的 API Key (provider 为 "openai" 时必填)
OPENAI_API_KEY=your_openai_api_key_here

# 原生 DeepSeek 模式下的 API Key (provider 为 "deepseek" 时必填)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 兼容 OpenAI 格式的代理/自建地址 (选填，比如你使用的是 Qwen、DeepSeek 的 API，或者中转站)
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# 指定要调用的模型名称 (选填，默认是 gpt-4o)
# OPENAI_MODEL=deepseek-v4-flash
